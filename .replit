modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.office365.com"
SMTP_PORT = "587"
SMTP_FROM = "noreply@mylocaltrade.co.uk"
SMTP_USER = "noreply@mylocaltrade.co.uk"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_qbWESyJrXDmlctafkOtDEaJqYTW"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_BIVAfGioOyQNZKAYqDNZkTtBnOk"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_qHukXmrQAVympYwzJvgUmuuFcrW"
REVENUECAT_PROJECT_ID = "proja2b11716"

[nix]
channel = "stable-25_05"
